  <script>
    function toggleFAQ(index) {
      const question = document.querySelectorAll('.faq-question')[index];
      const answer = document.getElementById(`faq-${index}`);
      
      // Close all others
      document.querySelectorAll('.faq-answer.active').forEach((el, i) => {
        if (i !== index) {
          el.classList.remove('active');
          document.querySelectorAll('.faq-question')[i].classList.remove('active');
        }
      });
      
      // Toggle current
      question.classList.toggle('active');
      answer.classList.toggle('active');
    }

    function openDownload() {
      // Replace with your actual app links
      window.open('https://play.google.com/store/apps/details?id=com.ascendquest', '_blank');
    }

    function scrollToHero() {
      document.getElementById('hero').scrollIntoView({ behavior: 'smooth' });
